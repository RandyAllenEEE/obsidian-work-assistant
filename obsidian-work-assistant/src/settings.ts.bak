addWeatherSettings(container: HTMLElement, lang: Language): void {
    const { enabled, warnings, tokenSecretId, hostSecretId, city, refreshInterval, dailyRefreshInterval } = this.plugin.options.assistant.weather;

    new Setting(container)
        .setName(t('settings-weather-title', lang))
        .setDesc(t('settings-weather-desc', lang))
        .addToggle((toggle) => {
            toggle.setValue(enabled);
            toggle.onChange(async (value) => {
                this.plugin.writeOptions((old) => ({
                    ...old,
                    assistant: {
                        ...old.assistant,
                        weather: {
                            ...old.assistant.weather,
                            enabled: value
                        }
                    }
                }));
            });
        });

    new Setting(container)
        .setName(t('settings-weather-city', lang))
        .setDesc(t('settings-weather-city-desc', lang))
        .addText((textfield) => {
            textfield.setValue(city);
            textfield.onChange(async (value) => {
                this.plugin.writeOptions((old) => ({
                    ...old,
                    assistant: {
                        ...old.assistant,
                        weather: {
                            ...old.assistant.weather,
                            city: value
                        }
                    }
                }));
            });
        });

    new Setting(container)
        .setName(t('settings-weather-token-secret-id', lang))
        .setDesc(t('settings-weather-token-secret-id-desc', lang))
        .addSecret((secret) => {
            secret.setValue(tokenSecretId);
            secret.onChange(async (value) => {
                this.plugin.writeOptions((old) => ({
                    ...old,
                    assistant: {
                        ...old.assistant,
                        weather: {
                            ...old.assistant.weather,
                            tokenSecretId: value
                        }
                    }
                }));
            });
        });

    new Setting(container)
        .setName(t('settings-weather-host-secret-id', lang))
        .setDesc(t('settings-weather-host-secret-id-desc', lang))
        .addSecret((secret) => {
            secret.setValue(hostSecretId);
            secret.onChange(async (value) => {
                this.plugin.writeOptions((old) => ({
                    ...old,
                    assistant: {
                        ...old.assistant,
                        weather: {
                            ...old.assistant.weather,
                            hostSecretId: value
                        }
                    }
                }));
            });
        });

    new Setting(container)
        .setName(t('settings-weather-refresh-interval', lang))
        .setDesc(t('settings-weather-refresh-interval-desc', lang))
        .addText((textfield) => {
            textfield.setPlaceholder("30");
            textfield.inputEl.type = "number";
            textfield.setValue(String(refreshInterval));
            textfield.onChange(async (value) => {
                const num = value !== "" ? Number(value) : 30;
                this.plugin.writeOptions((old) => ({
                    ...old,
                    assistant: {
                        ...old.assistant,
                        weather: {
                            ...old.assistant.weather,
                            refreshInterval: num
                        }
                    }
                }));
            });
        });

    new Setting(container)
        .setName(t('settings-weather-daily-refresh-interval', lang))
        .setDesc(t('settings-weather-daily-refresh-interval-desc', lang))
        .addText((textfield) => {
            textfield.setPlaceholder("4");
            textfield.inputEl.type = "number";
            textfield.setValue(String(dailyRefreshInterval));
            textfield.onChange(async (value) => {
                const num = value !== "" ? Number(value) : 4;
                this.plugin.writeOptions((old) => ({
                    ...old,
                    assistant: {
                        ...old.assistant,
                        weather: {
                            ...old.assistant.weather,
                            dailyRefreshInterval: num
                        }
                    }
                }));
            });
        });

    new Setting(container)
        .setName(t('settings-weather-warnings', lang))
        .setDesc(t('settings-weather-warnings-desc', lang))
        .addToggle((toggle) => {
            toggle.setValue(warnings);
            toggle.onChange(async (value) => {
                this.plugin.writeOptions((old) => ({
                    ...old,
                    assistant: {
                        ...old.assistant,
                        weather: {
                            ...old.assistant.weather,
                            warnings: value
                        }
                    }
                }));
            });
        });
}

private addCalendarViewSettings(container: HTMLElement, lang: Language): void {
    const { enabled, weekStart } = this.plugin.options.assistant.calendar;

    new Setting(container)
        .setName(t('settings-calendar-view-title', lang))
        // 添加正确的描述键
        .setDesc(t('settings-calendar-view-title-desc', lang))
        .addToggle((toggle) => {
            toggle.setValue(enabled);
            toggle.onChange(async (value) => {
                this.plugin.writeOptions((old) => ({
                    ...old,
                    assistant: {
                        ...old.assistant,
                        calendar: {
                            ...old.assistant.calendar,
                            enabled: value
                        }
                    }
                }));
            });
        });

    // 添加一周开始于设置
    new Setting(container)
        .setName(t('settings-start-week', lang))
        .setDesc(t('settings-start-week-desc', lang))
        .addDropdown((dropdown) => {
            dropdown.addOption("locale", t('settings-locale-default', lang).replace('{day}', 'Monday'));
            dropdown.addOption("monday", "星期一");
            dropdown.addOption("tuesday", "星期二");
            dropdown.addOption("wednesday", "星期三");
            dropdown.addOption("thursday", "星期四");
            dropdown.addOption("friday", "星期五");
            dropdown.addOption("saturday", "星期六");
            dropdown.addOption("sunday", "星期日");
            dropdown.setValue(weekStart);
            dropdown.onChange(async (value) => {
                this.plugin.writeOptions((old) => ({
                    ...old,
                    assistant: {
                        ...old.assistant,
                        calendar: {
                            ...old.assistant.calendar,
                            weekStart: value as IWeekStartOption
                        }
                    }
                }));
            });
        });
}
